{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manaka MOD Station",
  "version": "1.1.0",
  "identifier": "com.felixchaos.manaka-mod-station",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Manaka MOD Station",
        "width": 1280,
        "height": 840,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5QkY2MkMwOTlFRTg2MTMKUldRVGh1Nlp3R0svV2RxM3V0MTNNVzlzYkFGMjl2c21LRWtOYnI5YytSNkRSTUhQNEVkS09BWnQK",
      "endpoints": [
        "https://github.com/felixchaos/Manaka-MOD-Station/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
